# Narada environment — copy needed vars into ~/.hermes/.env (Hermes loads it)
# or export in the shell that runs the gateway.

# --- Core wiring -------------------------------------------------------------
# Absolute path to narada/tools in this checkout; skills invoke tools via this.
NARADA_TOOLS_DIR=/ABSOLUTE/PATH/TO/REPO/narada/tools

# --- Convex (cloud, convex.dev free tier) -------------------------------------
# HTTP actions domain (.convex.site, NOT .convex.cloud) serving POST /api/agent
CONVEX_URL=https://your-deployment.convex.site
# Shared secret checked by the Convex HTTP action (Authorization: Bearer ...)
CONVEX_AGENT_SECRET=change-me

# --- Telegram ------------------------------------------------------------------
# Bot token (shared with the Hermes gateway).
TELEGRAM_BOT_TOKEN=123456:ABC...
# OPEN BOT (D10): required opt-in — unset allowlist FAILS CLOSED (pairing/deny),
# it does not open the bot. See narada/config/hermes-config-snippet.yaml.
TELEGRAM_ALLOWED_USERS=*
# Default channel for publish_telegram_channel.py (@name or -100... id).
# Bot must be channel admin.
NARADA_TELEGRAM_CHANNEL=@your_channel
# Optional: separate bot for channel publishing (falls back to TELEGRAM_BOT_TOKEN)
# NARADA_TELEGRAM_BOT_TOKEN=

# --- Zernio (social publishing — primary publish surface) -----------------------
# API key from zernio.com dashboard; tools/zernio.py posts to connected accounts.
ZERNIO_API_KEY=zrn_...
# Optional override (default https://zernio.com/api/v1)
# ZERNIO_API_BASE=

# --- Email (Resend) ------------------------------------------------------------
RESEND_API_KEY=re_...
NARADA_EMAIL_FROM="Narada <hi@yourdomain.com>"   # must be Resend-verified

# --- Landing pages (Cloudflare) --------------------------------------------------
NARADA_PAGES_DIR=./narada-pages
# Set true ONLY when wrangler is installed + authed; false = write HTML only.
NARADA_WRANGLER_DEPLOY=false
NARADA_PAGES_PROJECT=narada-pages

# --- LinkedIn (P4, STUB — untested; see tools/publish_linkedin.py TODO) ----------
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=urn:li:person:XXXX

# LinkUp live search (researcher gana)
LINKUP_API_KEY=
