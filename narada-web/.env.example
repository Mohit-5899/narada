# Copy to .env.local and fill in after `npx convex dev` creates a deployment.
# Convex deployment URL (printed by `npx convex dev`, looks like https://xxx.convex.cloud)
VITE_CONVEX_URL=
# Telegram bot username (no @) for the deep-link handoff
VITE_TELEGRAM_BOT=NaradaMarketingBot

# Server-side env — set on the Convex deployment, NOT here:
#   npx convex env set AUTH_RESEND_KEY re_...        # magic-link email via Resend
#   npx convex env set SITE_URL http://localhost:5173 # where magic links redirect
#   npx convex env set AGENT_SHARED_SECRET <random>   # auth for POST /api/agent (Hermes backend)
